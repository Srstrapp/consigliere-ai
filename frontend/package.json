    "@angular/platform-server": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@angular/service-worker": "^21.1.0",
    "@angular/ssr": "^21.1.4",
    "@lucide/angular": "^1.7.0",
    "@supabase/supabase-js": "^2.102.1",
    "express": "^5.1.0",
    "gsap": "^3.14.2",
